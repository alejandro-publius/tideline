# Tideline backend configuration.
# Copy to `.env` and adjust, or export these as environment variables.
# Every setting has a sensible default (see backend/app/config.py); nothing
# here is required to run locally with SQLite.

# --- Storage -----------------------------------------------------------------
# SQLAlchemy database URL. Default is a local SQLite file.
# For a persistent deploy, point at Postgres, e.g.
#   postgresql+psycopg://user:pass@host:5432/tideline
TIDELINE_DATABASE_URL=sqlite:///./tideline.db

# --- NOAA upstream -----------------------------------------------------------
TIDELINE_NOAA_BASE_URL=https://api.tidesandcurrents.noaa.gov/api/prod/datagetter
TIDELINE_NOAA_MAX_RETRIES=3          # retries on transient (network / 5xx) failures
TIDELINE_NOAA_BACKOFF_BASE=0.5       # seconds; wait = base * 2**attempt
TIDELINE_NOAA_FAILURE_COOLDOWN_SECONDS=60  # serve stale after a failure instead of retrying per request (0 disables)

# --- Caching / freshness -----------------------------------------------------
TIDELINE_CACHE_TTL_MINUTES=10        # freshness window for observations
TIDELINE_PREDICTIONS_TTL_MINUTES=720 # freshness window for tide predictions
TIDELINE_HISTORY_REFRESH_MINUTES=30  # background surge-history sweep (0 disables)

# --- API surface -------------------------------------------------------------
TIDELINE_RATE_LIMIT_PER_MINUTE=120   # per-client token bucket (0 disables)
TIDELINE_CORS_ORIGINS=http://localhost:5173  # comma-separated (empty = CORS off)
TIDELINE_STATIC_DIR=                 # if set, serve the built frontend from here

# --- Ops ---------------------------------------------------------------------
TIDELINE_LOG_LEVEL=INFO
